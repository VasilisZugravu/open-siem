# Python virtualenv — never goes in the image
venv/
.venv/

# Local SQLite database (dev artefact)
siem.db

# Local secrets (never in image — use env vars / docker secrets)
.env

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Test artefacts
.pytest_cache/
*.egg-info/
dist/
build/

# Dataset files (log samples used for replay/testing)
data/

# Forwarder state files (runtime artefacts, not source)
.windows_forwarder_state.json
.linux_forwarder_state.json

# Editor and OS noise
.DS_Store
*.swp

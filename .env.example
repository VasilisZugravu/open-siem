# Copy this file to .env and fill in real values before running
# `docker compose up`. .env is gitignored — never commit real secrets.

# Postgres
POSTGRES_USER=siem
# Required — docker-compose will refuse to start if empty. Generate a strong
# random password: python -c "import secrets; print(secrets.token_hex(32))"
POSTGRES_PASSWORD=
POSTGRES_DB=siem

# Flask session signing key — required, no safe default. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Dashboard admin account, created/updated on container start.
# Both must be set — docker-compose will refuse to start if either is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Required for /ingest and /api/alerts to authenticate forwarders/clients.
# Generate the same way as SECRET_KEY.
INGEST_API_KEY=
# Forwarders and scripts (forwarders/*.py, scripts/replay_dataset.py, etc.) read
# SIEM_API_KEY first, then fall back to INGEST_API_KEY. Setting only INGEST_API_KEY
# above is enough for the bundled sources — no need to set SIEM_API_KEY separately
# unless you want to override the key for a specific forwarder.
# SIEM_API_KEY=
